# ─────────────────────────────────────────────────────────────────────────────
# COPIER CE FICHIER EN .env ET REMPLIR TOUTES LES VALEURS
# Ne jamais commiter le fichier .env dans Git
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Livroto SaaS"
APP_VERSION="1.0.0"
DEBUG=false
BASE_URL=https://votre-app.railway.app

# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_64_CHAR_RANDOM_STRING

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Base de données (Railway injecte DATABASE_URL automatiquement) ────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis (Railway injecte REDIS_URL automatiquement) ────────────────────────
REDIS_URL=redis://default:password@host:6379

# ── CORS ─────────────────────────────────────────────────────────────────────
# Séparer par virgule : https://monapp.com,https://admin.monapp.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── FlexPay Mobile Money (RDC) ───────────────────────────────────────────────
FLEXPAY_TOKEN=votre_token_flexpay
FLEXPAY_MERCHANT=votre_code_marchand
FLEXPAY_BASE_URL=https://backend.flexpay.cd/api/rest/v1
FLEXPAY_WEBHOOK_SECRET=secret_pour_valider_webhook

# ── Stripe (paiement international) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── WhatsApp Business API (Meta) ─────────────────────────────────────────────
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_VERIFY_TOKEN=mon_token_verification_whatsapp
WHATSAPP_API_VERSION=v20.0

# ── Twilio (SMS / OTP) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+12015551234

# ── Claude API (Anthropic) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
